INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Wand",6000.00,"Sorceror Wand (Hideous Laughter)","Subject loses actions for 1 round/level.",'{"Spell_Name":"Hideous Laughter","Class_Name":"Sorceror","Spell_Level":2,"Wand_Total_Cost":"6000.00","Spell_Short_Description":"Subject loses actions for 1 round/level.","Spell_Description":"      <p>This spell afflicts the subject with uncontrollable laughter. It collapses into gales of manic laughter, falling prone. The subject can take no actions while laughing, but is not considered helpless. After the spell ends, it can act normally.</p>      <p>A creature with an Intelligence score of 2 or lower is not affected. A creature whose type is different from the caster\"s receives a +4 bonus on its saving throw, because humor doesn\"t \"translate\" well.</p>      <p/>    "}')

