INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Weapon",30,"Waraxe, dwarven","null",'{"Item_ID":1,"Weapon_Name":"Waraxe, dwarven","Weapon_Category":"Exotic","Weapon_Type":"One-Handed Melee","Weapon_Cost":30,"Weapon_Small_Damage":"1d8","Weapon_Medium_Damage":"1d10","Weapon_Critical":"x3","Weapon_Range_Increment":null,"Weapon_Damage_Type":"Slashing","Weapon_Weight":"8.00","Weapon_Description":"A dwarven waraxe is too large to use in one hand without special training; thus it is an exotic weapon.\n    A medium character can use a dwarven waraxe two-handed as a martial weapon, or a large creature can use it one-handed in the same way. \n    A dwarf usually treats a dwarven waraxe as a martial weapon even when using it in one hand.","Weapon_Quantity":1,"Weapon_Material":null,"Weapon_Properties":[],"Double_Weapon_Properties":[],"Weapon_Cost_With_Properties":30}')

