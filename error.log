INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Weapon",30,"Shortbow","null",'{"Item_ID":1,"Weapon_Name":"Shortbow","Weapon_Category":"Martial","Weapon_Type":"Ranged","Weapon_Cost":30,"Weapon_Small_Damage":"1d4","Weapon_Medium_Damage":"1d6","Weapon_Critical":"x3","Weapon_Range_Increment":60,"Weapon_Damage_Type":"Piercing","Weapon_Weight":"2.00","Weapon_Description":"You need at least two hands to use a bow, regardless of its size. You can use a shortbow while mounted.\n    If you have a penalty for low Strength, apply it to damage rolls when you use a shortbow. If you have a bonus for high Strength, you can apply it to damage rolls when you use a composite shortbow, but not a regular shortbow.","Weapon_Quantity":1,"Weapon_Material":null,"Weapon_Properties":[],"Double_Weapon_Properties":[],"Weapon_Cost_With_Properties":30}')

