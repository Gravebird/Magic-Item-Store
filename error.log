INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Scroll",450.00,"Sorceror Scroll (Flame Arrow)","Arrows deal +1d6 fire damage.",'{"Spell_Name":"Flame Arrow","Class_Name":"Sorceror","Spell_Level":3,"Scroll_Total_Cost":"450.00","Spell_Short_Description":"Arrows deal +1d6 fire damage.","Spell_Description":"      <p>You turn ammunition (such as arrows, bolts, shuriken, and stones) into fiery projectiles. Each piece of ammunition deals an extra 1d6 points of fire damage to any target it hits. A flaming projectile can easily ignite a flammable object or structure, but it won\"t ignite a creature it strikes.</p>      <p/>    "}')

