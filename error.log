INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Scroll",200.00,"Sorceror Scroll (Hypnotic Pattern)","Fascinates (2d4 + level) HD of creatures.",'{"Spell_Name":"Hypnotic Pattern","Class_Name":"Sorceror","Spell_Level":2,"Scroll_Total_Cost":"200.00","Spell_Short_Description":"Fascinates (2d4 + level) HD of creatures.","Spell_Description":"      <p>A twisting pattern of subtle, shifting colors weaves through the air, fascinating creatures within it. Roll 2d4 and add your caster level (maximum 10) to determine the total number of Hit Dice of creatures affected. Creatures with the fewest HD are affected first; and, among creatures with equal HD, those who are closest to the spell\"s point of origin are affected first. Hit Dice that are not sufficient to affect a creature are wasted. Affected creatures become fascinated by the pattern of colors. Sightless creatures are not affected.</p>      <p>A wizard or sorcerer need not utter a sound to cast this spell, but a bard must sing, play music, or recite a rhyme as a verbal component.</p>      <p/>    "}')

