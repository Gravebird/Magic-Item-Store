INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Potion",50.00,"Potion (Magic fang)","One natural weapon of subject creature gets +1 on attack and damage rolls.",'{"Potion_Name":"Magic fang","Potion_Type":"potion","Potion_Cost":"50.00","Spell_Short_Description":"One natural weapon of subject creature gets +1 on attack and damage rolls.","Spell_Description":"      <p><i>Magic fang</i> gives one natural weapon of the subject a +1 enhancement bonus on attack and damage rolls. The spell can affect a slam attack, fist, bite, or other natural weapon. (The spell does not change an unarmed strike\"s damage from nonlethal damage to lethal damage.)</p>      <p><i>Magic fang</i> can be made permanent with a <i>permanency</i> spell.</p>      <p/>    "}')

