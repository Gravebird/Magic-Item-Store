INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Weapon",6,"Sickle","null",'{"Item_ID":1,"Weapon_Name":"Sickle","Weapon_Category":"Simple","Weapon_Type":"Light Melee","Weapon_Cost":6,"Weapon_Small_Damage":"1d4","Weapon_Medium_Damage":"1d6","Weapon_Critical":"x2","Weapon_Range_Increment":null,"Weapon_Damage_Type":"Slashing","Weapon_Weight":"2.00","Weapon_Description":"This weapon is like a farmers sickle, but it is strengthened for use as a weapon.\n    It is favored by druids and by anyone who wants a weapon that might be overlooked by guards.\n    Because of a sickles shape, you can use it to make trip attacks.\n    If you are tripped during your own trip attempt, you can drop the sickle to avoid being tripped.","Weapon_Quantity":1,"Weapon_Material":null,"Weapon_Properties":[],"Double_Weapon_Properties":[],"Weapon_Cost_With_Properties":6}')

