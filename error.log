INSERT INTO Item (shop_id,Item_Type,Item_Cost,Item_Name,Item_Short_Description,Item_JSON) VALUES (1,"Potion",750.00,"Potion (Flame arrow)","Arrows deal +1d6 fire damage.",'{"Potion_Name":"Flame arrow","Potion_Type":"oil","Potion_Cost":"750.00","Spell_Short_Description":"Arrows deal +1d6 fire damage.","Spell_Description":"      <p>You turn ammunition (such as arrows, bolts, shuriken, and stones) into fiery projectiles. Each piece of ammunition deals an extra 1d6 points of fire damage to any target it hits. A flaming projectile can easily ignite a flammable object or structure, but it won\"t ignite a creature it strikes.</p>      <p/>    "}')

